# Auto-Pricer Worker Configuration
# Copy this to .env and fill in values

# tm-dash production URL (Vercel)
DASHBOARD_URL=https://craig-accounts.vercel.app

# Shared secret — must match TM_STOCK_WORKER_SECRET in Vercel env vars
WORKER_SECRET=your-shared-secret-here

# How often to run the refresh cycle (seconds). Default: 90
INTERVAL_SEC=90

# Health endpoint port. Default: 8002 (tm-stock=8000, tm-gen=8001)
HEALTH_PORT=8002

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
